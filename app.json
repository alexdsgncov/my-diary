{
  "expo": {
    "name": "My Diary",
    "slug": "my-diary",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.mydiary.app",
      "permissions": []
    },
    "plugins": [
      "expo-router",
      [
        "expo-haptics"
      ]
    ],
    "scheme": "mydiary",
    "experiments": {
      "typedRoutes": true
    }
  }
}
